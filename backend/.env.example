# Mission Control Dashboard — Backend Config
# Copy to .env and fill in your values

# OpenViking memory server
OPENVIKING_URL=http://127.0.0.1:1933
OPENVIKING_KEY=your-api-key

# MCP servers
MEMORY_MCP_URL=http://127.0.0.1:2033/mcp
OPENCLAW_MCP_URL=http://127.0.0.1:2034/mcp

# Local LLM servers
OLLAMA_URL=http://localhost:11434
MLX_SERVER_URL=http://127.0.0.1:8081

# Mesh identity (shown in agent cards)
MESH_HOST=localhost
MESH_OPERATOR=operator
